from pyspark.sql import Window, functions as F

sf = spark.table(f"{CATALOG}.{SCHEMA}.silver_flights_vk").filter("cancelled=0")

gold_route_otp = (sf.groupBy("flight_date", "route_id")
                  
                  .agg(F.count("*").alias("departures"),
                       F.round(F.avg("dep_delay_min"),1).alias("avg_dep_delay"),
                       F.round(F.avg("on_time")*100,1).alias("otp_pct"),
                       F.sum(F.when(F.col("controllable_flag")=="Y",1).otherwise(0)).alias("controllable_delays")))

(gold_route_otp.write.format("delta").mode("overwrite").saveAsTable(f"{CATALOG}.{SCHEMA}.gold_route_otp"))


