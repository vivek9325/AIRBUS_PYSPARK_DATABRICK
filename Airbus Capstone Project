from pyspark.sql.types import (StructType, StructField, StringType, IntegerType, DoubleType)

sensor_schema = StructType([StructField("reading_id", StringType()),
                           StructField("tail_number", StringType()),
                           StructField("engine_position", IntegerType()),
                           StructField("ts_utc", StringType()),
                           StructField("flight_id", StringType()),
                           StructField("egt_c", DoubleType()),
                           StructField("n1_pct", DoubleType()),
                           StructField("n2_pct", DoubleType()),   
                           StructField("oil_temp_c", DoubleType()),   
                           StructField("oil_pressure_psi", DoubleType()),   
                           StructField("vib_ips", DoubleType()),  
                           StructField("fuel_flow_pph", DoubleType()),                       
                           
                           ])

stream = (spark.readStream.format("cloudFiles")
          .option("cloudFiles.format", "json")
          .option("cloudFiles.schemaLocation", f"{CHK}/sensors_schema")
          .schema(sensor_schema)
          .load(f"{LANDING}/sensors/")
          .withColumn("_ingest_ts", F.current_timestamp())
          .withColumn("_source_file", F.col("_metadata.file_path")))
       
(stream.writeStream
   .format("delta")
   .option("checkpointLocation", f"{CHK}/bronze_sensors")
   .trigger(availableNow=True)        # process what's here, then stop
   .toTable(f"{CATALOG}.{SCHEMA}.bronze_engine_telemetry")
   .awaitTermination())

print("rows:", spark.table(f"{CATALOG}.{SCHEMA}.bronze_engine_telemetry").count())   
          
